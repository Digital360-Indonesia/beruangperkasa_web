---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 6);

const products = [
  { name: 'Semen Putih Black Bull', category: 'Semen', excerpt: 'Semen putih berkualitas tinggi untuk finishing dan dekorasi bangunan.' },
  { name: 'Perekat Bata Ringan Big Lion', category: 'Perekat', excerpt: 'Perekat bata ringan 5 in 1 untuk berbagai jenis pasangan.' },
  { name: 'Plamir Instant Big Lion', category: 'Plamir', excerpt: 'Plamir siap pakai untuk finishing dinding yang rata dan halus.' },
  { name: 'Acian Abu-abu Giant Mortar', category: 'Acian', excerpt: 'Acian siap pakai untuk interior dan eksterior.' },
  { name: 'Super Joint Compound', category: 'Plamir', excerpt: 'Plamir dengan daya rekat tinggi untuk permukaan dinding.' },
  { name: 'Wall Care', category: 'Perawatan', excerpt: 'Pelindung dinding agar tetap bersih dan tahan lama.' },
];
---

<BaseLayout title="Home" description="CV Beruang Perkasa - Distributor Semen Putih, Perekat Bata Ringan, Plamir, Acian dan Bahan Bangunan Berkualitas">
  <section class="hero">
    <div class="container-xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-6xl font-bold mb-6">
        Profesional Dan Komitmen<br />
        Menguasai Pangsa Pasar<br />
        Hampir Seluruh Indonesia
      </h1>
      <p class="text-xl text-gray-300 mb-8 max-w-2xl mx-auto">
        Melalui Distribusi Bahan Bangunan Berkualitas
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/products" class="btn btn-primary">
          Lihat Produk
          <span class="hero-arrow">&#8594;</span>
        </a>
        <a href="/contact" class="btn btn-outline">
          Hubungi Kami
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container-xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Produk Unggulan</h2>
        <p class="text-gray text-lg max-w-xl mx-auto">Bahan bangunan berkualitas tinggi untuk kebutuhan konstruksi Anda</p>
      </div>
      <div class="product-grid">
        {products.map((product) => (
          <div class="product-card">
            <div class="product-card-image">
              <span class="text-gray-400">{product.category}</span>
            </div>
            <div class="product-card-body">
              <span class="badge mb-2">{product.category}</span>
              <h3 class="product-card-title mt-2">{product.name}</h3>
              <p class="product-card-text">{product.excerpt}</p>
              <a href="/products" class="product-card-link">
                Selengkapnya <span>&#8594;</span>
              </a>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/products" class="btn btn-outline-primary">
          Lihat Semua Produk
        </a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container-xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Artikel Terbaru</h2>
        <p class="text-gray text-lg max-w-xl mx-auto">Tips dan informasi seputar bahan bangunan</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {recentPosts.map((post) => {
          const slug = post.data.slug || post.id;
          return (
            <a href={`/posts/${slug}`} class="block bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
              <div class="p-6">
                <h3 class="font-bold text-lg mb-2 line-clamp-2">{post.data.title}</h3>
                <p class="text-gray text-sm line-clamp-3">{post.data.excerpt || 'Baca artikel lengkap tentang bahan bangunan...'}</p>
                <span class="text-red mt-4 inline-block text-sm font-medium">Baca Selengkapnya &#8594;</span>
              </div>
            </a>
          );
        })}
      </div>
      <div class="text-center mt-8">
        <a href="/posts" class="btn btn-primary">
          Lihat Semua Artikel
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary text-white">
    <div class="container-xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Tentang CV Beruang Perkasa</h2>
      <p class="text-lg mb-8 max-w-2xl mx-auto text-white opacity-90">
        Telah dipercaya sejak 2010 sebagai distributor bahan bangunan terpercaya di Surabaya dan seluruh Indonesia.
        Produk kami meliputi Semen Putih, Perekat Bata Ringan, Plamir, Acian, dan berbagai bahan bangunan berkualitas lainnya.
      </p>
      <a href="/about" class="btn bg-white text-primary hover:bg-gray-100">
        Pelajari Lebih Lanjut
      </a>
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container-xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Hubungi Kami</h2>
          <p class="text-gray text-lg mb-6">
            Konsultasikan kebutuhan bahan bangunan Anda dengan tim kami. Kami siap membantu memberikan rekomendasi produk yang tepat untuk proyek Anda.
          </p>
          <div class="flex gap-4">
            <a href="/contact" class="btn btn-primary">
              Hubungi Kami
            </a>
            <a href="https://wa.me/62813333333871" class="btn btn-outline-primary">
              WhatsApp
            </a>
          </div>
        </div>
        <div class="bg-white rounded-lg shadow-md p-8">
          <h3 class="font-bold text-xl mb-4">Kontak</h3>
          <p class="text-gray mb-2">Surabaya, Indonesia</p>
          <p class="text-gray mb-2">Email: info@beruangperkasa.com</p>
          <p class="text-gray">WhatsApp: +62 812 3456 7890</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>