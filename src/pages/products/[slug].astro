---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.data.slug || product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);
---

<BaseLayout title={product.data.title} description={product.data.excerpt}>
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-red-600 transition-colors">Beranda</a>
        <span>/</span>
        <a href="/products" class="hover:text-red-600 transition-colors">Produk</a>
        {product.data.category && (
          <>
            <span>/</span>
            <a href={`/products?filter=category&value=${encodeURIComponent(product.data.category)}`} class="hover:text-red-600 transition-colors">{product.data.category}</a>
          </>
        )}
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="aspect-square bg-gray-100 rounded-2xl overflow-hidden relative">
          {product.data.image ? (
            <img src={product.data.image} alt={product.data.title} class="w-full h-full object-cover">
          ) : (
            <div class="absolute inset-0 bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
              <span class="text-8xl font-bold text-gray-300">{product.data.title.charAt(0)}</span>
            </div>
          )}
        </div>

        <div class="flex flex-col">
          <div class="flex flex-wrap gap-3 mb-4">
            {product.data.solution && (
              <span class="px-4 py-2 text-sm font-medium bg-green-500 text-white rounded-full">{product.data.solution}</span>
            )}
            {product.data.category && (
              <span class="px-4 py-2 text-sm font-medium bg-red-100 text-red-700 rounded-full">{product.data.category}</span>
            )}
          </div>

          <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-6">{product.data.title}</h1>

          {product.data.excerpt && (
            <p class="text-lg text-gray-600 mb-8 leading-relaxed">{product.data.excerpt}</p>
          )}

          <div class="prose prose-lg max-w-none border-t pt-8">
            <Content />
          </div>

          <div class="mt-auto pt-8 border-t">
            <a href="/products" class="inline-flex items-center gap-2 px-6 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium rounded-lg transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
              </svg>
              Kembali ke Produk
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>