---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { slug: product.data.slug || product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await render(product);

const getImage = (imagePath) => {
  if (!imagePath || imagePath === '') return '/uploads/woocommerce-placeholder-1200x800.png';
  return imagePath;
};
---

<BaseLayout title={product.data.title} description={product.data.excerpt}>
  <section class="py-12 bg-white">
    <div class="container mx-auto px-4">
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-red-600 transition-colors">Beranda</a>
        <span>/</span>
        <a href="/products" class="hover:text-red-600 transition-colors">Produk</a>
        {product.data.category && (
          <>
            <span>/</span>
            <a href={`/products?filter=category&value=${encodeURIComponent(product.data.category)}`} class="hover:text-red-600 transition-colors">{product.data.category}</a>
          </>
        )}
      </nav>

      <div class="product-image-wrapper">
          {product.data.image ? (
            <img src={getImage(product.data.image)} alt={product.data.title} class="product-image" />
          ) : (
            <div class="product-image-placeholder">
              <span class="text-8xl font-bold text-gray-300">{product.data.title.charAt(0)}</span>
            </div>
          )}
        </div>

        <div class="product-info">
          <div class="product-meta">
            {product.data.category && (
              <span class="product-category">{product.data.category}</span>
            )}
            {product.data.solution && (
              <span class="product-solution">{product.data.solution}</span>
            )}
          </div>

          <h1 class="product-title">{product.data.title}</h1>

          {product.data.excerpt && (
            <p class="product-excerpt">{product.data.excerpt}</p>
          )}

          <div class="product-share">
            <span class="share-label">Bagikan:</span>
            <a href={`https://wa.me/?text=${encodeURIComponent(product.data.title + ' - https://beruangperkasa.id/products/' + (product.data.slug || product.id))}`} class="share-btn" aria-label="Share to WhatsApp">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=https://beruangperkasa.id/products/${product.data.slug || product.id}`} class="share-btn" aria-label="Share to Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          </div>
        </div>
      </div>

      <div class="product-detail">
        <h2 class="detail-title">Deskripsi Produk</h2>
        <div class="product-content">
          <Content />
        </div>
      </div>

      <div class="product-footer">
        <div class="product-tags">
          <span class="tag">{product.data.category || 'Produk'}</span>
          <span class="tag">Bahan Bangunan</span>
          <span class="tag">{product.data.solution || 'Konstruksi'}</span>
        </div>
        <a href="/products" class="back-link">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Kembali ke Produk
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .product-image-wrapper {
    background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
    border-radius: 1rem;
    overflow: hidden;
    max-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .product-image {
    max-width: 100%;
    max-height: 400px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .product-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  .product-info {
    display: flex;
    flex-direction: column;
    max-width: 800px;
    margin: 0 auto 3rem;
  }

  .product-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .product-category {
    display: inline-flex;
    align-items: center;
    background: var(--primary);
    color: var(--white);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product-solution {
    display: inline-flex;
    align-items: center;
    background: var(--accent-green);
    color: var(--white);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .product-title {
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .product-excerpt {
    font-size: 1.125rem;
    color: #6b7280;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .product-share {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .share-label {
    color: #6b7280;
    font-size: 0.875rem;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #f3f4f6;
    color: #6b7280;
    transition: all 0.2s;
  }

  .share-btn:hover {
    background: var(--primary);
    color: var(--white);
  }

  .product-detail {
    max-width: 800px;
    margin: 0 auto 3rem;
  }

  .detail-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--primary);
    display: inline-block;
  }

  .product-content {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #374151;
  }

  .product-content :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .product-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-dark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .product-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-dark);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .product-content :global(ul),
  .product-content :global(ol) {
    margin: 1.5rem 0;
    padding-left: 1.5rem;
  }

  .product-content :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .product-content :global(strong) {
    font-weight: 600;
    color: var(--text-dark);
  }

  .product-content :global(em) {
    font-style: italic;
  }

  .product-content :global(a) {
    color: var(--primary);
    text-decoration: underline;
  }

  .product-content :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #6b7280;
  }

  .product-content :global(img) {
    max-width: 150px;
    height: auto;
    border-radius: 0.5rem;
    margin: 1rem 0;
  }

  .product-footer {
    max-width: 800px;
    margin: 0 auto;
    padding-top: 2rem;
    border-top: 1px solid #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: #f3f4f6;
    color: #6b7280;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9375rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--primary-dark);
  }

  .back-link svg {
    transition: transform 0.2s;
  }

  .back-link:hover svg {
    transform: translateX(-4px);
  }

  @media (max-width: 768px) {
    .product-image-wrapper {
      max-height: 300px;
    }

    .product-image {
      max-height: 300px;
    }

    .product-title {
      font-size: 1.75rem;
    }

    .product-content {
      font-size: 1rem;
    }

    .product-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>