---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const products = await getCollection('products');

const solutions = ['Rumah', 'Anti Bocor', 'Ramah Lingkungan', 'Area Terbuka', 'Furnitur & Kerajinan'];
const categories = ['Semen Putih', 'Perekat Bata Ringan', 'Plamir & Acian', 'Cat Tembok', 'Pengikat & Lem', 'Produk Pendukung'];

const getImage = (imagePath) => {
  if (!imagePath || imagePath === '') return '/uploads/woocommerce-placeholder-1200x800.png';
  return imagePath;
};
---

<BaseLayout title="Produk" description="Produk bahan bangunan berkualitas dari Beruang Perkasa">
  <section class="section py-12">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl font-bold mb-4">Produk Kami</h1>
        <p class="text-gray text-lg max-w-xl mx-auto">Pilihan bahan bangunan berkualitas untuk kebutuhan konstruksi Anda</p>
      </div>

      <div class="mb-12">
        <div class="flex flex-wrap gap-3 justify-center items-center">
          <span class="text-sm font-bold text-gray-500 mr-2">Solusi:</span>
          {solutions.map(s => (
            <button class="filter-btn px-4 py-2 text-sm font-medium rounded-full transition-all" data-filter="solution" data-value={s}>
              {s}
            </button>
          ))}
        </div>
        <div class="flex flex-wrap gap-3 justify-center items-center" style="margin-top: 20px;">
          <span class="text-sm font-bold text-gray-500 mr-2">Kategori:</span>
          {categories.map(c => (
            <button class="filter-btn px-4 py-2 text-sm font-medium rounded-full transition-all" data-filter="category" data-value={c}>
              {c}
            </button>
          ))}
        </div>
      </div>

      <div id="productsGrid" class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-3 gap-6">
        {products.map((product) => (
          <a
            href={`/products/${product.data.slug || product.id}`}
            class="product-card group"
            data-solution={product.data.solution || ''}
            data-category={product.data.category || ''}
          >
            <div class="product-image">
              <img src={getImage(product.data.image)} alt={product.data.title} width="400" height="370" loading="lazy" decoding="async" />
            </div>
            <div class="product-content">
              <span class="product-badge">{product.data.category || 'Produk'}</span>
              <h3 class="product-title">{product.data.title}</h3>
              <span class="product-link">Selengkapnya &#8594;</span>
            </div>
          </a>
        ))}
      </div>

      <div id="noResults" class="hidden text-center py-16">
        <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M12 2a10 10 0 100 20 10 10 0 000-20z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-gray-900 mb-2">Tidak ada produk</h3>
        <p class="text-gray-500">Coba pilih filter lainnya</p>
      </div>
    </div>
  </section>

  <style>
    .product-card {
      background: var(--white);
      border-radius: 0.75rem;
      overflow: hidden;
      box-shadow: 0 1px 4px rgba(0,0,0,0.04);
      transition: all 0.25s ease;
      display: flex;
      flex-direction: column;
      border: 1px solid rgba(0,0,0,0.06);
    }

    .product-card:hover {
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
      transform: translateY(-3px);
      border-color: rgba(228, 21, 32, 0.2);
    }

    .product-image {
      height: 370px;
      overflow: hidden;
      background: linear-gradient(135deg, #f5f5f5 0%, #e8e8e8 100%);
    }

    .product-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .product-card:hover .product-image img {
      transform: scale(1.08);
    }

    .product-content {
      padding: 1.25rem 1.5rem 1.5rem;
      display: flex;
      flex-direction: column;
    }

    .product-badge {
      display: inline-block;
      background: linear-gradient(135deg, var(--primary) 0%, #c41018 100%);
      color: var(--white);
      padding: 0.5rem 1rem;
      border-radius: 2rem;
      font-size: 0.8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      margin-bottom: 0.75rem;
      width: fit-content;
    }

    .product-title {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text-dark);
      line-height: 1.4;
      margin-bottom: 1rem;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      transition: color 0.3s;
    }

    .product-card:hover .product-title {
      color: var(--primary);
    }

    .product-link {
      color: var(--primary);
      font-weight: 600;
      font-size: 0.875rem;
    }

    .filter-btn {
      background: white;
      color: #4b5563;
      border: 2px solid #e5e7eb;
      border-radius: 9999px;
      font-size: 1rem;
    }

    .filter-btn:hover {
      border-color: var(--primary);
      color: var(--primary);
      background: rgba(228, 21, 32, 0.04);
    }

    .filter-btn.active {
      background: var(--primary);
      color: white;
      border-color: var(--primary);
      box-shadow: 0 4px 15px rgba(228, 21, 32, 0.35);
    }

    .filter-section-gap {
      margin-top: 24px;
    }

    .text-gray {
      color: var(--text-gray);
    }

    @media (max-width: 1024px) {
      .product-image {
        height: 330px;
      }
    }

    @media (max-width: 768px) {
      .product-image {
        height: 300px;
      }
    }

    .product-card.hidden {
      display: none !important;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tabs = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.product-card');
      const noResults = document.getElementById('noResults');
      const urlParams = new URLSearchParams(window.location.search);
      const initialFilter = urlParams.get('filter') || 'all';
      const initialValue = decodeURIComponent(urlParams.get('value') || '');

      function decodeAttrValue(text: string): string {
        const textarea = document.createElement('textarea');
        textarea.innerHTML = text;
        return textarea.value;
      }

      function getAttrValue(attr: string | undefined): string {
        return decodeAttrValue(attr || '');
      }

      function applyFilter(filter: string, value: string) {
        let visibleCount = 0;
        cards.forEach(card => {
          const cardEl = card as HTMLElement;
          const solution = getAttrValue(cardEl.dataset.solution);
          const category = getAttrValue(cardEl.dataset.category);

          let show = false;
          if (filter === 'all') {
            show = true;
          } else if (filter === 'solution') {
            show = solution === value;
          } else if (filter === 'category') {
            show = category === value;
          }

          cardEl.classList.toggle('hidden', !show);
          if (show) visibleCount++;
        });

        if (noResults) noResults.classList.toggle('hidden', visibleCount > 0);

        tabs.forEach(tab => {
          tab.classList.remove('active');
          const tabEl = tab as HTMLElement;
          const tabFilter = tabEl.dataset.filter || '';
          const tabValue = getAttrValue(tabEl.dataset.value);
          if (filter === 'all' && tabFilter === 'all') {
            tab.classList.add('active');
          } else if (tabFilter === filter && tabValue === value) {
            tab.classList.add('active');
          }
        });
      }

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const tabEl = tab as HTMLElement;
          const filter = tabEl.dataset.filter || 'all';
          const value = getAttrValue(tabEl.dataset.value);

          const url = new URL(window.location.href);
          if (filter === 'all') {
            url.searchParams.delete('filter');
            url.searchParams.delete('value');
          } else {
            url.searchParams.set('filter', filter);
            url.searchParams.set('value', encodeURIComponent(value));
          }
          window.history.pushState({}, '', url);

          applyFilter(filter, value);
        });
      });

      applyFilter(initialFilter, initialValue);
    });
  </script>
</BaseLayout>