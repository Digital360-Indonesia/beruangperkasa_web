---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const products = await getCollection('products');
---

<BaseLayout title="Produk" description="Produk bahan bangunan berkualitas: Semen Putih, Perekat Bata Ringan, Plamir, Acian dari Beruang Perkasa">
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-center mb-4">Produk Kami</h1>
      <p class="text-gray-600 text-center mb-12">Pilihan bahan bangunan berkualitas untuk kebutuhan konstruksi Anda</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product) => (
          <a href={`/products/${product.data.slug || product.id}`} class="block bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
            <div class="p-6">
              <h2 class="font-bold text-lg mb-2 hover:text-red-600">{product.data.title}</h2>
              <p class="text-gray-600 text-sm line-clamp-3">{product.data.excerpt || 'Lihat detail produk...'}</p>
              <span class="text-red-600 mt-4 inline-block text-sm">Selengkapnya &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
