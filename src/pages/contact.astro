---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontak" description="Hubungi CV Beruang Perkasa untuk informasi produk dan pemesanan">
  <section class="py-16">
    <div class="container mx-auto px-4 max-w-3xl">
      <h1 class="text-4xl font-bold mb-8">Hubungi Kami</h1>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div>
          <h2 class="text-2xl font-bold mb-4">Informasi Kontak</h2>

          <div class="space-y-4">
            <div>
              <h3 class="font-semibold text-lg">Alamat</h3>
              <p class="text-gray-600">Surabaya, Indonesia</p>
            </div>

            <div>
              <h3 class="font-semibold text-lg">Website</h3>
              <p class="text-gray-600">https://beruangperkasa.id</p>
            </div>

            <div>
              <h3 class="font-semibold text-lg">Media Sosial</h3>
              <p class="text-gray-600">
                <a href="https://facebook.com/CV-Beruang-Perkasa-Group-100822325102507" class="text-red-600 hover:underline">Facebook</a>
              </p>
              <p class="text-gray-600">
                <a href="https://www.instagram.com/beruangperkasa/" class="text-red-600 hover:underline">Instagram</a>
              </p>
            </div>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold mb-4">Kirim Pesan</h2>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-1">Nama</label>
              <input type="text" name="name" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-red-600" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Email</label>
              <input type="email" name="email" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-red-600" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1">Pesan</label>
              <textarea name="message" rows="4" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-red-600"></textarea>
            </div>
            <button type="submit" class="bg-red-600 text-white px-6 py-3 rounded font-semibold hover:bg-red-700 transition">
              Kirim Pesan
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
