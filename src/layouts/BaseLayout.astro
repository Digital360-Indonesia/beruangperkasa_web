---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'CV Beruang Perkasa - Distributor Semen Putih dan Bahan Bangunan Berkualitas' } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Beruang Perkasa</title>
    <link rel="icon" type="image/png" href="/uploads/2020/12/logo-bulat.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&family=Martel:wght@400;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="header">
      <nav class="header-nav">
        <a href="/" class="header-logo">
          <img src="/uploads/2020/12/logo.png" alt="Beruang Perkasa" />
          <span class="header-brand">Beruang Perkasa</span>
        </a>
        <ul class="header-menu">
          <li><a href="/">Home</a></li>
          <li><a href="/products">Produk</a></li>
          <li><a href="/posts">Blog</a></li>
          <li><a href="/about">Tentang Kami</a></li>
          <li><a href="/contact">Kontak</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div>
            <img src="/uploads/2020/12/logo.png" alt="Beruang Perkasa" style="height: 3rem; margin-bottom: 1rem;" />
            <p>Distributor bahan bangunan berkualitas untuk seluruh Indonesia.</p>
          </div>
          <div>
            <h4>Produk</h4>
            <ul>
              <li><a href="/products">Semen Putih</a></li>
              <li><a href="/products">Perekat Bata Ringan</a></li>
              <li><a href="/products">Plamir & Acian</a></li>
              <li><a href="/products">Skim Coat</a></li>
            </ul>
          </div>
          <div>
            <h4>Perusahaan</h4>
            <ul>
              <li><a href="/about">Tentang Kami</a></li>
              <li><a href="/contact">Kontak</a></li>
              <li><a href="/posts">Blog</a></li>
            </ul>
          </div>
          <div>
            <h4>Kontak</h4>
            <p>Surabaya, Indonesia</p>
            <ul style="margin-top: 0.5rem;">
              <li><a href="https://facebook.com/CV-Beruang-Perkasa-Group-100822325102507">Facebook</a></li>
              <li><a href="https://www.instagram.com/beruangperkasa/">Instagram</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <p>&copy; 2024 Beruang Perkasa. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
